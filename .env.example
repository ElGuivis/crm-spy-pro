# ============================================================
# Variáveis de ambiente — geradas automaticamente pelo Lovable Cloud
# NÃO contêm segredos privados (apenas chaves públicas/anon).
# Este arquivo serve como referência; o .env real é auto-gerenciado.
#
# Política completa: docs/ENV_POLICY.md
# ============================================================

VITE_SUPABASE_PROJECT_ID="your-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-anon-key"
VITE_SUPABASE_URL="https://your-project-id.supabase.co"

# ============================================================
# SEGREDOS PRIVADOS — NUNCA devem estar no .env ou no código!
# São gerenciados via Lovable Cloud > Secrets:
#
#   SUPABASE_SERVICE_ROLE_KEY
#   CRON_SECRET
#   META_APP_SECRET
#   INSTAGRAM_APP_SECRET
#   BLING_CLIENT_SECRET
#   MELHOR_ENVIO_CLIENT_SECRET
#   EVOLUTION_API_KEY
#   (e outros listados no painel de Secrets)
#
# Esses segredos ficam disponíveis apenas em Edge Functions
# e nunca são expostos ao navegador.
# ============================================================
